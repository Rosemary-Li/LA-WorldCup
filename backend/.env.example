# PostgreSQL (DigitalOcean managed cluster — required)
DB_HOST=your-db-host
DB_PORT=25060
DB_NAME=your-db-name
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_SSLMODE=require

# Anthropic — used for /api/match-story (optional; circuit breaker on failure)
# ANTHROPIC_API_KEY=sk-ant-...

# API-Football (api-sports.io) — used for /api/match-stats (optional; falls back to bundled data)
# API_FOOTBALL_KEY=your-key
